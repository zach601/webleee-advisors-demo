---
import SiteLayout from '../components/SiteLayout.astro';
import ServiceGrid from '../components/ServiceGrid.astro';

const title = 'Services | Meridian & Co Advisors Demo';
const description = 'Explore fictional advisory, tax planning, accounting, compliance, strategy, reporting, and risk review services for Meridian & Co Advisors.';
---

<SiteLayout title={title} description={description} path="/services/">
  <section class="border-b border-line bg-paper">
    <div class="container-shell grid gap-10 py-16 lg:grid-cols-[0.7fr_1.3fr] lg:items-end">
      <div class="border-l-4 border-gold pl-6">
        <p class="eyebrow">Services</p>
        <h1 class="page-heading mt-4">A service register, not a sales brochure.</h1>
      </div>
      <p class="body-copy max-w-3xl lg:justify-self-end">
        Meridian & Co Advisors is fictional. This page shows how a professional firm can explain scope, fit, and example outputs without implying real client work or guaranteed results.
      </p>
    </div>
  </section>

  <section class="section-pad bg-ivory">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.32fr_1fr]">
      <aside class="document-panel h-fit p-6">
        <p class="field-label">Use this page for</p>
        <ul class="mt-5 space-y-4 text-sm leading-6 text-slate">
          <li>Explaining complex scope in plain language.</li>
          <li>Helping prospects self-select the right service area.</li>
          <li>Creating a more serious tone than generic service cards.</li>
        </ul>
      </aside>
      <ServiceGrid />
    </div>
  </section>

  <section class="section-pad bg-navy text-ivory">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.7fr_1.3fr]">
      <div>
        <p class="eyebrow">Service Structure</p>
        <h2 class="font-display text-4xl leading-tight text-ivory sm:text-5xl">Each engagement needs a clear frame before advice begins.</h2>
      </div>
      <div class="divide-y divide-ivory/10 border-y border-ivory/10">
        {[
          ['Scope', 'Define what the service covers and where the engagement begins.'],
          ['Records', 'Gather reports, documents, policies, schedules, and planning context.'],
          ['Review', 'Assess obligations, risks, options, and decision priorities.'],
          ['Roadmap', 'Create practical next steps for follow-up conversations.']
        ].map((item) => (
          <article class="grid gap-3 py-6 sm:grid-cols-[0.28fr_1fr]">
            <h3 class="font-display text-3xl text-ivory">{item[0]}</h3>
            <p class="text-sm leading-6 text-ivory/70">{item[1]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
