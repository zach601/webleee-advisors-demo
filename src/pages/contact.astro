---
import SiteLayout from '../components/SiteLayout.astro';

const title = 'Contact | Meridian & Co Advisors Demo';
const description = 'Request a fictional consultation with Meridian & Co Advisors, a professional services website demo by Webleee.';
---

<SiteLayout title={title} description={description} path="/contact/">
  <section class="bg-ivory">
    <div class="container-shell grid gap-10 py-20 lg:grid-cols-[0.82fr_1.18fr]">
      <div>
        <p class="eyebrow">Consultation Request</p>
        <h1 class="page-heading mt-4">Start with a focused conversation.</h1>
        <p class="body-copy mt-6">
          This form is a static UI for a fictional professional services demo. It does not create real consultations or advisory engagements.
        </p>
        <div class="mt-8 space-y-4 border border-line bg-paper p-6 text-sm text-slate">
          <p><strong class="text-navy">Phone:</strong> Phone placeholder for demo</p>
          <p><strong class="text-navy">Email:</strong> Email placeholder for demo</p>
          <p><strong class="text-navy">Office:</strong> Office location placeholder</p>
          <p><strong class="text-navy">Business Hours:</strong> Business hours placeholder</p>
        </div>
      </div>

      <form class="board-card p-6 sm:p-8" aria-label="Consultation request form">
        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-bold text-navy">Name</span>
            <input class="mt-2 w-full border border-line bg-ivory px-4 py-3 text-ink outline-none focus:border-gold" type="text" name="name" placeholder="Your name" />
          </label>
          <label class="block">
            <span class="text-sm font-bold text-navy">Company</span>
            <input class="mt-2 w-full border border-line bg-ivory px-4 py-3 text-ink outline-none focus:border-gold" type="text" name="company" placeholder="Company name" />
          </label>
          <label class="block sm:col-span-2">
            <span class="text-sm font-bold text-navy">Email</span>
            <input class="mt-2 w-full border border-line bg-ivory px-4 py-3 text-ink outline-none focus:border-gold" type="email" name="email" placeholder="you@example.com" />
          </label>
          <label class="block">
            <span class="text-sm font-bold text-navy">Service Area</span>
            <select class="mt-2 w-full border border-line bg-ivory px-4 py-3 text-ink outline-none focus:border-gold" name="service">
              <option>Business advisory</option>
              <option>Tax planning</option>
              <option>Accounting support</option>
              <option>Compliance support</option>
              <option>Strategy consulting</option>
              <option>Risk review</option>
            </select>
          </label>
          <label class="block">
            <span class="text-sm font-bold text-navy">Preferred Contact</span>
            <select class="mt-2 w-full border border-line bg-ivory px-4 py-3 text-ink outline-none focus:border-gold" name="contact-method">
              <option>Email</option>
              <option>Phone</option>
              <option>Video call</option>
            </select>
          </label>
          <label class="block sm:col-span-2">
            <span class="text-sm font-bold text-navy">Message</span>
            <textarea class="mt-2 min-h-36 w-full border border-line bg-ivory px-4 py-3 text-ink outline-none focus:border-gold" name="message" placeholder="Tell us what you would like to discuss"></textarea>
          </label>
        </div>
        <p class="mt-6 text-sm leading-6 text-slate">
          Demo note: this form is not connected to a backend and does not submit real enquiries.
        </p>
        <button type="button" class="primary-button mt-4">Demo Consultation Form</button>
      </form>
    </div>
  </section>

  <section class="section-pad bg-paper">
    <div class="container-shell grid gap-8 lg:grid-cols-[1fr_0.9fr] lg:items-stretch">
      <div class="board-card p-8">
        <p class="eyebrow">Office Placeholder</p>
        <div class="mt-6 flex min-h-[340px] items-center justify-center bg-blue text-center">
          <p class="max-w-sm text-sm leading-6 text-slate">A real advisory firm website could include office directions, parking notes, or a map embed here. This demo keeps the site static and fast.</p>
        </div>
      </div>
      <div class="bg-navy p-8 text-ivory">
        <p class="eyebrow">Careful Next Steps</p>
        <h2 class="mt-4 font-display text-4xl leading-tight text-ivory">Built for qualified business enquiries.</h2>
        <p class="mt-4 text-sm leading-6 text-ivory/70">
          The contact page gives prospects a structured way to identify the service area, context, and preferred next step without making real advisory promises.
        </p>
      </div>
    </div>
  </section>
</SiteLayout>
