---
import SiteLayout from '../components/SiteLayout.astro';
import InsightCards from '../components/InsightCards.astro';

const title = 'Insights | Meridian & Co Advisors Demo';
const description = 'Fictional professional services insight previews for Meridian & Co Advisors, covering growth, tax season, reporting, and stronger business systems.';
---

<SiteLayout title={title} description={description} path="/insights/">
  <section class="border-b border-line bg-paper">
    <div class="container-shell grid gap-8 py-16 lg:grid-cols-[0.75fr_1.25fr] lg:items-end">
      <p class="eyebrow">Insights</p>
      <div>
        <h1 class="page-heading max-w-4xl">A publication index for serious business readers.</h1>
        <p class="body-copy mt-6 max-w-3xl">
          These fictional article previews show tone and structure only. They are not real advisory work, client outcomes, financial advice, or legal advice.
        </p>
      </div>
    </div>
  </section>

  <section class="section-pad bg-ivory">
    <div class="container-shell">
      <InsightCards />
    </div>
  </section>

  <section class="section-pad bg-paper">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.42fr_1fr]">
      <div>
        <p class="eyebrow">Editorial Pillars</p>
        <h2 class="section-heading mt-3">Topics a real firm could adapt with qualified advice.</h2>
      </div>
      <div class="divide-y divide-line border-y border-line">
        {[
          ['Growth Planning', 'Use structured content to help prospects understand strategic advisory topics.'],
          ['Reporting Discipline', 'Present finance and operations themes in a calm, boardroom-ready format.'],
          ['Risk Awareness', 'Discuss process and governance without making legal or financial promises.']
        ].map((item) => (
          <article class="grid gap-3 bg-ivory px-5 py-6 sm:grid-cols-[0.28fr_1fr]">
            <h3 class="font-display text-3xl text-navy">{item[0]}</h3>
            <p class="text-sm leading-6 text-slate">{item[1]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
