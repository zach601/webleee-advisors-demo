---
import SiteLayout from '../components/SiteLayout.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import InsightCards from '../components/InsightCards.astro';

const title = 'Meridian & Co Advisors | Premium Advisory Website Demo by Webleee';
const description = 'A fictional professional services website demo for accountants, lawyers, consultants, financial advisors, brokers, and business service firms.';
---

<SiteLayout title={title} description={description}>
  <section class="border-b border-line bg-paper">
    <div class="container-shell grid gap-10 py-16 lg:grid-cols-[0.9fr_1.1fr] lg:items-stretch lg:py-24">
      <div class="flex flex-col justify-between gap-10">
        <div>
          <p class="eyebrow">Professional Services Website Demo</p>
          <h1 class="display-heading mt-5">A boardroom-ready website for measured advice.</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate">
            Meridian & Co Advisors is a fictional advisory firm concept. The design shows how Webleee can present complex services with restraint, structure, and clear enquiry paths.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a href="/contact/" class="primary-button">Request Consultation</a>
          <a href="/insights/" class="secondary-button">Read Briefings</a>
        </div>
      </div>

      <div class="document-panel">
        <div class="border-b border-line bg-navy px-6 py-5 text-ivory">
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-ivory/60">Board Brief</p>
          <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <h2 class="font-display text-4xl">Meridian & Co Advisors</h2>
            <span class="text-xs font-bold uppercase tracking-wide text-gold">Sample firm profile</span>
          </div>
        </div>
        <div class="divide-y divide-line px-6">
          {[
            ['Position', 'Careful advisory support for business owners and leadership teams.'],
            ['Tone', 'Measured, plain-spoken, and appropriate for accounting, legal, finance, and consulting websites.'],
            ['Proof Standard', 'No real clients, reviews, awards, certifications, or guaranteed outcomes are claimed.'],
            ['Primary Action', 'A structured consultation request that gathers useful context before a call.']
          ].map((row) => (
            <div class="grid gap-2 py-5 sm:grid-cols-[0.28fr_1fr]">
              <p class="field-label">{row[0]}</p>
              <p class="text-sm leading-6 text-slate">{row[1]}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad bg-ivory">
    <div class="container-shell">
      <div class="mb-10 max-w-3xl">
        <p class="eyebrow">Service Register</p>
        <h2 class="section-heading mt-3">Services organized like a professional engagement file.</h2>
        <p class="body-copy mt-4">
          Instead of generic tiles, the services are arranged as a reference table a prospect can scan quickly before enquiring.
        </p>
      </div>
      <ServiceGrid />
    </div>
  </section>

  <section class="section-pad bg-navy text-ivory">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <p class="eyebrow">Who This Fits</p>
        <h2 class="font-display text-4xl leading-tight text-ivory sm:text-5xl">A website structure for firms where trust is earned quietly.</h2>
      </div>
      <div class="grid gap-px overflow-hidden border border-ivory/10 bg-ivory/10 md:grid-cols-3">
        {[
          ['Owner-led companies', 'Need advisory services explained without making the site feel sales-heavy.'],
          ['Professional practices', 'Need clear service scope, thoughtful tone, and simple enquiry routing.'],
          ['Specialist consultants', 'Need insights, process, and positioning to support high-consideration decisions.']
        ].map((segment) => (
          <article class="bg-navy p-6">
            <h3 class="font-display text-3xl text-ivory">{segment[0]}</h3>
            <p class="mt-4 text-sm leading-6 text-ivory/68">{segment[1]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-paper">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="eyebrow">Decision File</p>
        <h2 class="section-heading mt-3">A calmer path from enquiry to next steps.</h2>
      </div>
      <div class="document-panel px-6">
        {[
          ['01', 'Initial context', 'The prospect explains the business issue, service area, and urgency.'],
          ['02', 'Document review', 'The firm organizes records, reports, obligations, and practical constraints.'],
          ['03', 'Options memo', 'The conversation turns into clear tradeoffs, priorities, and possible next steps.'],
          ['04', 'Ongoing support', 'Follow-up work is framed around a defined scope and review rhythm.']
        ].map((step) => (
          <article class="document-row">
            <p class="font-display text-3xl text-gold">{step[0]}</p>
            <h3 class="font-display text-2xl text-navy">{step[1]}</h3>
            <p class="text-sm leading-6 text-slate">{step[2]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-ivory">
    <div class="container-shell">
      <div class="mb-10 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="eyebrow">Briefing Library</p>
          <h2 class="section-heading mt-3">Publication-style insights for serious readers.</h2>
        </div>
        <a href="/insights/" class="secondary-button lg:mb-1">Open Insights</a>
      </div>
      <InsightCards />
    </div>
  </section>

  <section class="bg-gold py-14 text-navy">
    <div class="container-shell grid gap-6 lg:grid-cols-[1fr_0.45fr] lg:items-center">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-navy/70">Consultation CTA</p>
        <h2 class="mt-3 font-display text-4xl leading-tight sm:text-5xl">Make the first enquiry feel structured.</h2>
      </div>
      <a href="/contact/" class="inline-flex min-h-12 items-center justify-center bg-navy px-6 py-3 text-sm font-bold uppercase tracking-wide text-ivory transition hover:bg-paper hover:text-navy focus:outline-none focus:ring-2 focus:ring-navy focus:ring-offset-2 focus:ring-offset-gold">Request Consultation</a>
    </div>
  </section>
</SiteLayout>
