---
const insights = [
  ['Preparing your business for growth', 'A fictional guide to reviewing systems, reporting, team capacity, and decision cadence before expansion.'],
  ['What to review before tax season', 'A practical checklist-style preview for records, deadlines, obligations, and planning conversations.'],
  ['How better reporting improves decisions', 'A short advisory article concept about turning finance data into clearer management decisions.'],
  ['Building stronger business systems', 'A fictional operations-focused insight on repeatable processes, controls, and accountability rhythms.']
];
---

<div class="grid gap-5 md:grid-cols-2">
  {insights.map((insight) => (
    <article class="board-card p-7">
      <p class="eyebrow">Fictional Insight</p>
      <h3 class="mt-4 font-display text-3xl leading-tight text-navy">{insight[0]}</h3>
      <p class="mt-4 text-sm leading-6 text-slate">{insight[1]}</p>
      <p class="mt-8 border-t border-line pt-4 text-xs font-bold uppercase tracking-wide text-gold">Article preview</p>
    </article>
  ))}
</div>
