---
import '../styles/global.css';

const {
  title,
  description,
  path = '/',
  image = 'https://images.unsplash.com/photo-1497366811353-6870744d04b2?auto=format&fit=crop&w=1600&q=80'
} = Astro.props;

const siteName = 'Meridian & Co Advisors';
const canonical = `https://webleee-advisors-demo.pages.dev${path}`;
const navigation = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services' },
  { href: '/about/', label: 'About' },
  { href: '/insights/', label: 'Insights' },
  { href: '/contact/', label: 'Contact' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
  </head>
  <body>
    <header class="border-b border-line bg-paper">
      <div class="container-shell flex items-center justify-between border-b border-line py-2 text-[0.68rem] font-bold uppercase tracking-[0.22em] text-slate">
        <span>Professional services sample</span>
        <span class="hidden sm:inline">Fictional advisory firm concept</span>
      </div>
      <nav class="container-shell grid gap-4 py-5 lg:grid-cols-[0.7fr_1fr_0.45fr] lg:items-center" aria-label="Primary navigation">
        <a href="/" class="group inline-flex items-baseline gap-3" aria-label="Meridian and Co Advisors home">
          <span class="font-display text-3xl leading-none text-navy">Meridian & Co</span>
          <span class="hidden text-xs font-bold uppercase tracking-[0.18em] text-gold sm:inline">Advisors</span>
        </a>
        <div class="flex gap-2 overflow-x-auto lg:justify-center">
          {navigation.map((item) => (
            <a class="shrink-0 border border-line bg-ivory px-4 py-2 text-xs font-bold uppercase tracking-wide text-slate transition hover:border-gold hover:text-navy focus:outline-none focus:ring-2 focus:ring-gold" href={item.href}>{item.label}</a>
          ))}
        </div>
        <a href="/contact/" class="secondary-button justify-self-start lg:justify-self-end">Enquiry Memo</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-line bg-paper text-navy">
      <div class="container-shell grid gap-10 py-12 lg:grid-cols-[1.1fr_0.7fr_1fr]">
        <div class="border-l-4 border-gold pl-6">
          <p class="eyebrow">Portfolio Demo</p>
          <h2 class="mt-3 font-display text-3xl">Meridian & Co Advisors</h2>
          <p class="mt-4 max-w-xl text-sm leading-6 text-slate">
            Fictional professional services website created by Webleee for portfolio use. It does not represent a real advisory firm, client work, certification, or financial/legal advice.
          </p>
        </div>
        <div>
          <h3 class="text-sm font-bold uppercase tracking-wide text-gold">Pages</h3>
          <ul class="mt-4 space-y-2 text-sm text-slate">
            {navigation.map((item) => (
              <li><a class="hover:text-navy" href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="border border-line bg-ivory p-6">
          <h3 class="text-sm font-bold uppercase tracking-wide text-gold">Contact</h3>
          <ul class="mt-4 space-y-2 text-sm text-slate">
            <li>Phone placeholder for demo</li>
            <li>Email placeholder for demo</li>
            <li>Office location placeholder</li>
          </ul>
        </div>
      </div>
      <div class="border-t border-line py-5">
        <div class="container-shell flex flex-col gap-2 text-xs font-semibold uppercase tracking-wide text-slate sm:flex-row sm:items-center sm:justify-between">
          <span>Demo website by Webleee</span>
          <span>Fictional professional services demo</span>
        </div>
      </div>
    </footer>
  </body>
</html>
