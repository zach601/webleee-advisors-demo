---
const services = [
  ['01', 'Business Advisory', 'Owner decisions, operating priorities, growth options, and management cadence.', 'Decision notes, action priorities, review rhythm.'],
  ['02', 'Tax Planning', 'Planning copy for fictional businesses preparing records, timing, and obligations.', 'Record checklist, planning questions, deadline view.'],
  ['03', 'Accounting Support', 'Monthly financial administration, bookkeeping coordination, and cleaner reporting habits.', 'Month-end rhythm, handover list, review notes.'],
  ['04', 'Compliance Support', 'Policy, filing, documentation, and readiness workflows for regulated teams.', 'Obligation register, evidence list, responsibility map.'],
  ['05', 'Strategy Consulting', 'Focused planning sessions around positioning, services, and operating constraints.', 'Workshop agenda, options memo, next-step plan.'],
  ['06', 'Financial Reporting', 'Management report structures that make performance easier to discuss.', 'Dashboard outline, metric set, commentary template.'],
  ['07', 'Risk Review', 'Process, governance, continuity, and internal-control conversations without guarantees.', 'Risk register, control notes, improvement priorities.']
];
---

<div class="document-panel">
  <div class="grid gap-4 bg-navy px-5 py-4 text-xs font-bold uppercase tracking-[0.18em] text-ivory/70 md:grid-cols-[0.18fr_0.32fr_1fr_0.55fr]">
    <span>Ref</span>
    <span>Service</span>
    <span>Use Case</span>
    <span>Example Output</span>
  </div>
  {services.map((service) => (
    <article class="grid gap-4 border-t border-line px-5 py-5 md:grid-cols-[0.18fr_0.32fr_1fr_0.55fr] md:items-start">
      <p class="font-display text-3xl text-gold">{service[0]}</p>
      <h3 class="font-display text-2xl leading-tight text-navy">{service[1]}</h3>
      <p class="text-sm leading-6 text-slate">{service[2]}</p>
      <p class="text-sm font-semibold leading-6 text-navy">{service[3]}</p>
    </article>
  ))}
</div>
